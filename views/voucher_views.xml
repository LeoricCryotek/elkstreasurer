<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sequence for voucher numbers -->
    <record id="seq_voucher" model="ir.sequence">
        <field name="name">Elks Payment Voucher</field>
        <field name="code">elks.voucher</field>
        <field name="prefix">VCH-%(year)s-</field>
        <field name="padding">4</field>
    </record>

    <!-- ============================================================
         Form View
         ============================================================ -->
    <record id="view_voucher_form" model="ir.ui.view">
        <field name="name">elks.voucher.form</field>
        <field name="model">elks.voucher</field>
        <field name="arch" type="xml">
            <form string="Payment Voucher">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,board,floor,approved,posted"/>

                    <!-- Draft → Board -->
                    <button name="action_submit_to_board" type="object"
                            string="Submit to Board"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <!-- Board actions -->
                    <button name="action_board_approve" type="object"
                            string="Board Approve"
                            class="btn-primary"
                            invisible="state != 'board'"
                            groups="elkstreasurer.group_elkstreasurer_manager"/>
                    <button name="action_board_reject" type="object"
                            string="Board Reject"
                            class="btn-danger"
                            invisible="state != 'board'"
                            groups="elkstreasurer.group_elkstreasurer_manager"/>

                    <!-- Floor actions -->
                    <button name="action_floor_approve" type="object"
                            string="Floor Approve"
                            class="btn-primary"
                            invisible="state != 'floor'"
                            groups="elkstreasurer.group_elkstreasurer_manager"/>
                    <button name="action_floor_reject" type="object"
                            string="Floor Reject"
                            class="btn-danger"
                            invisible="state != 'floor'"
                            groups="elkstreasurer.group_elkstreasurer_manager"/>

                    <!-- Post (create journal entry) -->
                    <button name="action_post" type="object"
                            string="Post Voucher"
                            class="btn-primary"
                            invisible="state != 'approved'"
                            groups="elkstreasurer.group_elkstreasurer_manager"/>

                    <!-- Reset rejected → draft -->
                    <button name="action_reset_to_draft" type="object"
                            string="Reset to Draft"
                            invisible="state != 'rejected'"/>

                    <!-- Print voucher -->
                    <button name="action_print_voucher" type="object"
                            string="Preview Voucher"
                            icon="fa-eye"
                            invisible="state not in ('approved', 'posted')"/>
                    <button name="action_download_voucher_pdf" type="object"
                            string="Download Voucher PDF"
                            icon="fa-download"
                            invisible="state not in ('approved', 'posted')"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Voucher Details">
                            <field name="payee_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': False}"/>
                            <field name="voucher_type"
                                   readonly="state != 'draft'"/>
                            <field name="amount"
                                   readonly="state != 'draft'"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="request_date"
                                   readonly="state != 'draft'"/>
                            <field name="date_needed"
                                   readonly="state != 'draft'"/>
                            <field name="requested_by"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group string="Accounting">
                            <field name="elks_account_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="elks_department_id" readonly="1"/>
                            <field name="payment_account_id"
                                   readonly="state in ('posted',)"
                                   required="state == 'approved'"
                                   options="{'no_create': True}"/>
                            <field name="check_number"
                                   readonly="state == 'posted'"/>
                            <field name="budget_line_id" readonly="1"
                                   invisible="not budget_line_id"/>
                            <field name="budget_available" readonly="1"
                                   invisible="not budget_line_id"/>
                            <field name="over_budget" invisible="1"/>
                            <div colspan="2"
                                 invisible="not over_budget"
                                 class="alert alert-warning mb-0 mt-2"
                                 role="alert">
                                <strong>Over Budget:</strong>
                                This voucher exceeds the available budget for
                                the selected GL account. A budget transfer may
                                be needed before approval.
                            </div>
                            <field name="journal_entry_id" readonly="1"
                                   invisible="not journal_entry_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="memo"
                               readonly="state != 'draft'"
                               placeholder="What is this payment for? (prints on the voucher)"/>
                    </group>

                    <!-- Approval details -->
                    <group string="Approval History"
                           invisible="state in ('draft', 'board')">
                        <group>
                            <field name="board_approved_by" readonly="1"/>
                            <field name="board_approved_on" readonly="1"/>
                        </group>
                        <group>
                            <field name="floor_approved_by" readonly="1"
                                   invisible="state in ('floor',) and not floor_approved_by"/>
                            <field name="floor_approved_on" readonly="1"
                                   invisible="state in ('floor',) and not floor_approved_on"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes"
                                   placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================
         List View
         ============================================================ -->
    <record id="view_voucher_tree" model="ir.ui.view">
        <field name="name">elks.voucher.tree</field>
        <field name="model">elks.voucher</field>
        <field name="arch" type="xml">
            <list string="Payment Vouchers"
                  decoration-warning="state == 'board'"
                  decoration-info="state == 'floor'"
                  decoration-success="state in ('approved', 'posted')"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="request_date"/>
                <field name="payee_id"/>
                <field name="voucher_type"/>
                <field name="memo" optional="show"/>
                <field name="amount" sum="Total"/>
                <field name="elks_account_id" optional="show"/>
                <field name="check_number" optional="show"/>
                <field name="payment_account_id" optional="hide"/>
                <field name="requested_by" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'board'"
                       decoration-info="state == 'floor'"
                       decoration-success="state in ('approved', 'posted')"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         Search View
         ============================================================ -->
    <record id="view_voucher_search" model="ir.ui.view">
        <field name="name">elks.voucher.search</field>
        <field name="model">elks.voucher</field>
        <field name="arch" type="xml">
            <search string="Payment Vouchers">
                <field name="name"/>
                <field name="payee_id"/>
                <field name="memo"/>
                <field name="elks_account_id"/>
                <field name="check_number"/>
                <separator/>
                <filter name="filter_draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_board" string="Board Review"
                        domain="[('state', '=', 'board')]"/>
                <filter name="filter_floor" string="Floor Vote"
                        domain="[('state', '=', 'floor')]"/>
                <filter name="filter_approved" string="Approved"
                        domain="[('state', '=', 'approved')]"/>
                <filter name="filter_posted" string="Posted"
                        domain="[('state', '=', 'posted')]"/>
                <filter name="filter_rejected" string="Rejected"
                        domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter name="filter_pending_approval"
                        string="Pending Approval"
                        domain="[('state', 'in', ['board', 'floor'])]"/>
                <group>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_payee" string="Payee"
                            context="{'group_by': 'payee_id'}"/>
                    <filter name="group_type" string="Purpose"
                            context="{'group_by': 'voucher_type'}"/>
                    <filter name="group_account" string="GL Account"
                            context="{'group_by': 'elks_account_id'}"/>
                    <filter name="group_month" string="Month"
                            context="{'group_by': 'request_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         Actions
         ============================================================ -->
    <record id="action_vouchers" model="ir.actions.act_window">
        <field name="name">Payment Vouchers</field>
        <field name="res_model">elks.voucher</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_vouchers_pending" model="ir.actions.act_window">
        <field name="name">Pending Vouchers</field>
        <field name="res_model">elks.voucher</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['board', 'floor'])]</field>
    </record>

</odoo>
