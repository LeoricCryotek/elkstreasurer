<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="res_groups_privilege_elkstreasurer" model="res.groups.privilege">
            <field name="name">Elks Treasurer</field>
            <field name="category_id" ref="base.module_category_productivity"/>
            <field name="sequence">60</field>
        </record>

        <record id="group_elkstreasurer_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="res_groups_privilege_elkstreasurer"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_elkstreasurer_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_elkstreasurer"/>
            <field name="sequence">10</field>
            <field name="implied_ids" eval="[(4, ref('group_elkstreasurer_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
