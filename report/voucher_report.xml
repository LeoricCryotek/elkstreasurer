<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Report action — HTML preview -->
    <record id="action_report_voucher" model="ir.actions.report">
        <field name="name">Payment Voucher</field>
        <field name="model">elks.voucher</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">elkstreasurer.report_voucher</field>
        <field name="report_file">elkstreasurer.report_voucher</field>
        <field name="print_report_name">'Voucher_%s' % object.name</field>
        <field name="binding_model_id" ref="model_elks_voucher"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Companion PDF report for download -->
    <record id="action_report_voucher_pdf" model="ir.actions.report">
        <field name="name">Payment Voucher (PDF)</field>
        <field name="model">elks.voucher</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">elkstreasurer.report_voucher</field>
        <field name="report_file">elkstreasurer.report_voucher</field>
        <field name="print_report_name">'Voucher_%s' % object.name</field>
        <field name="binding_model_id" ref="model_elks_voucher"/>
        <field name="binding_type">report</field>
    </record>

    <!-- QWeb template -->
    <template id="report_voucher">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.internal_layout">
                    <t t-set="settings"
                       t-value="doc.env['elks.lodge.settings'].sudo().search([], limit=1)"/>

                    <div class="page" style="font-family: Arial, sans-serif;">
                        <!-- ===== LODGE HEADER WITH LOGOS ===== -->
                        <table style="width: 100%; margin-bottom: 20px; border: none;">
                            <tr>
                                <td style="width: 15%; text-align: center; vertical-align: middle; border: none; padding: 0;">
                                    <t t-if="settings and settings.logo_primary">
                                        <img t-att-src="image_data_uri(settings.logo_primary)"
                                             style="max-height: 80px; max-width: 100px;"
                                             alt="Elks USA"/>
                                    </t>
                                </td>
                                <td style="text-align: center; vertical-align: middle; border: none; padding: 0 10px;">
                                    <h2 style="font-size: 26px; margin: 0 0 2px 0; color: #333;">
                                        <t t-if="settings and settings.name">
                                            <span t-field="settings.name"/>
                                        </t>
                                        <t t-else="">Elks Lodge</t>
                                        <t t-if="settings and settings.lodge_number">
                                            #<span t-field="settings.lodge_number"/>
                                        </t>
                                    </h2>
                                    <p style="color: #777; font-size: 12px; margin: 0;">
                                        Benevolent and Protective Order of Elks
                                    </p>
                                    <h3 style="font-size: 20px; margin: 8px 0 0 0; color: #1b5e20;">
                                        Payment Voucher
                                    </h3>
                                </td>
                                <td style="width: 15%; text-align: center; vertical-align: middle; border: none; padding: 0;">
                                    <t t-if="settings and settings.logo_lodge">
                                        <img t-att-src="image_data_uri(settings.logo_lodge)"
                                             style="max-height: 80px; max-width: 100px;"
                                             alt="Lodge Logo"/>
                                    </t>
                                </td>
                            </tr>
                        </table>

                        <!-- Divider -->
                        <div style="border-top: 2px solid #1b5e20; margin-bottom: 20px;"/>

                        <!-- Reference and Date -->
                        <table style="width: 100%; margin-bottom: 20px; border: none;">
                            <tr>
                                <td style="border: none; font-size: 14px;">
                                    <strong>Voucher #:</strong>
                                    <span t-field="doc.name"
                                          style="font-size: 16px; font-weight: bold; color: #1b5e20;"/>
                                </td>
                                <td style="border: none; text-align: right; font-size: 14px;">
                                    <strong>Date:</strong>
                                    <span t-field="doc.request_date"
                                          t-options='{"widget": "date", "format": "MM/dd/yyyy"}'/>
                                </td>
                            </tr>
                        </table>

                        <!-- Voucher Details Table -->
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                            <tr style="background: #e8f5e9;">
                                <td style="border: 1px solid #ccc; padding: 10px 14px; width: 30%; font-weight: bold; color: #555;">
                                    Pay To
                                </td>
                                <td style="border: 1px solid #ccc; padding: 10px 14px; font-size: 15px;">
                                    <span t-field="doc.payee_id"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #ccc; padding: 10px 14px; font-weight: bold; color: #555;">
                                    Amount
                                </td>
                                <td style="border: 1px solid #ccc; padding: 10px 14px; font-size: 18px; font-weight: bold; color: #1b5e20;">
                                    <span t-field="doc.amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                            </tr>
                            <tr style="background: #e8f5e9;">
                                <td style="border: 1px solid #ccc; padding: 10px 14px; font-weight: bold; color: #555;">
                                    Purpose
                                </td>
                                <td style="border: 1px solid #ccc; padding: 10px 14px;">
                                    <span t-field="doc.voucher_type"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #ccc; padding: 10px 14px; font-weight: bold; color: #555;">
                                    GL Account (Charge To)
                                </td>
                                <td style="border: 1px solid #ccc; padding: 10px 14px;">
                                    <span t-field="doc.elks_account_id"/>
                                    <t t-if="doc.elks_department_id">
                                        <span style="color: #999;"> — </span>
                                        <span t-field="doc.elks_department_id"/>
                                    </t>
                                </td>
                            </tr>
                            <tr style="background: #e8f5e9;">
                                <td style="border: 1px solid #ccc; padding: 10px 14px; font-weight: bold; color: #555;">
                                    Pay From Account
                                </td>
                                <td style="border: 1px solid #ccc; padding: 10px 14px;">
                                    <t t-if="doc.payment_account_id">
                                        <span t-field="doc.payment_account_id"/>
                                    </t>
                                    <t t-else="">
                                        <span style="color: #999;">Not yet assigned</span>
                                    </t>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #ccc; padding: 10px 14px; font-weight: bold; color: #555;">
                                    Check Number
                                </td>
                                <td style="border: 1px solid #ccc; padding: 10px 14px;">
                                    <t t-if="doc.check_number">
                                        <span t-field="doc.check_number"
                                              style="font-size: 15px; font-weight: bold;"/>
                                    </t>
                                    <t t-else="">
                                        <span style="color: #999;">________________</span>
                                    </t>
                                </td>
                            </tr>
                            <tr style="background: #e8f5e9;">
                                <td style="border: 1px solid #ccc; padding: 10px 14px; font-weight: bold; color: #555; vertical-align: top;">
                                    Memo / Description
                                </td>
                                <td style="border: 1px solid #ccc; padding: 10px 14px;">
                                    <span t-field="doc.memo"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #ccc; padding: 10px 14px; font-weight: bold; color: #555;">
                                    Requested By
                                </td>
                                <td style="border: 1px solid #ccc; padding: 10px 14px;">
                                    <span t-field="doc.requested_by"/>
                                </td>
                            </tr>
                            <tr style="background: #e8f5e9;">
                                <td style="border: 1px solid #ccc; padding: 10px 14px; font-weight: bold; color: #555;">
                                    Date Needed
                                </td>
                                <td style="border: 1px solid #ccc; padding: 10px 14px;">
                                    <t t-if="doc.date_needed">
                                        <span t-field="doc.date_needed"
                                              t-options='{"widget": "date", "format": "MM/dd/yyyy"}'/>
                                    </t>
                                    <t t-else="">
                                        <span style="color: #999;">No deadline</span>
                                    </t>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #ccc; padding: 10px 14px; font-weight: bold; color: #555;">
                                    Status
                                </td>
                                <td style="border: 1px solid #ccc; padding: 10px 14px;">
                                    <span t-field="doc.state"/>
                                    <t t-if="doc.journal_entry_id">
                                        <span style="color: #999;"> — Journal Entry: </span>
                                        <span t-field="doc.journal_entry_id"/>
                                    </t>
                                </td>
                            </tr>
                        </table>

                        <!-- Approval History -->
                        <t t-if="doc.board_approved_by or doc.floor_approved_by">
                            <h4 style="color: #1b5e20; margin: 20px 0 10px 0;">Approval History</h4>
                            <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                                <thead>
                                    <tr style="background: #1b5e20; color: white;">
                                        <th style="border: 1px solid #ccc; padding: 8px 14px; text-align: left;">Stage</th>
                                        <th style="border: 1px solid #ccc; padding: 8px 14px; text-align: left;">Approved By</th>
                                        <th style="border: 1px solid #ccc; padding: 8px 14px; text-align: left;">Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-if="doc.board_approved_by">
                                        <tr>
                                            <td style="border: 1px solid #ccc; padding: 8px 14px;">Board</td>
                                            <td style="border: 1px solid #ccc; padding: 8px 14px;">
                                                <span t-field="doc.board_approved_by"/>
                                            </td>
                                            <td style="border: 1px solid #ccc; padding: 8px 14px;">
                                                <span t-field="doc.board_approved_on"
                                                      t-options='{"widget": "date", "format": "MM/dd/yyyy"}'/>
                                            </td>
                                        </tr>
                                    </t>
                                    <t t-if="doc.floor_approved_by">
                                        <tr>
                                            <td style="border: 1px solid #ccc; padding: 8px 14px;">Floor</td>
                                            <td style="border: 1px solid #ccc; padding: 8px 14px;">
                                                <span t-field="doc.floor_approved_by"/>
                                            </td>
                                            <td style="border: 1px solid #ccc; padding: 8px 14px;">
                                                <span t-field="doc.floor_approved_on"
                                                      t-options='{"widget": "date", "format": "MM/dd/yyyy"}'/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Signature Lines -->
                        <div style="margin-top: 50px;">
                            <table style="width: 100%; border: none;">
                                <tr>
                                    <td style="width: 30%; border: none; padding-top: 40px;">
                                        <div style="border-top: 1px solid #333; padding-top: 4px; text-align: center; font-size: 12px; color: #555;">
                                            Treasurer Signature
                                        </div>
                                    </td>
                                    <td style="width: 5%; border: none;"/>
                                    <td style="width: 30%; border: none; padding-top: 40px;">
                                        <div style="border-top: 1px solid #333; padding-top: 4px; text-align: center; font-size: 12px; color: #555;">
                                            Secretary Signature
                                        </div>
                                    </td>
                                    <td style="width: 5%; border: none;"/>
                                    <td style="width: 30%; border: none; padding-top: 40px;">
                                        <div style="border-top: 1px solid #333; padding-top: 4px; text-align: center; font-size: 12px; color: #555;">
                                            Bookkeeper Signature
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Footer note -->
                        <p style="text-align: center; font-size: 10px; color: #aaa; margin-top: 30px;">
                            This document is an official record of the
                            <t t-if="settings and settings.name">
                                <span t-field="settings.name"/>
                            </t>
                            <t t-else="">Elks Lodge</t>.
                            Retain for audit purposes.
                        </p>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
